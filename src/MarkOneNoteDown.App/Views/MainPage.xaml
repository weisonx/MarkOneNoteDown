<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="MarkOneNoteDown.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MarkOneNoteDown.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    Background="{StaticResource PageBackgroundBrush}"
    mc:Ignorable="d">
    <Grid Padding="24" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="6">
            <TextBlock Style="{StaticResource TitleText}" Text="MarkOneNoteDown" />
            <TextBlock Style="{StaticResource SubtitleText}" Text="OneNote to Markdown export pipeline (WinUI 3)" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Source" />
                <TextBlock Text="Notebooks" />
                <ListView x:Name="NotebooksList"
                          DisplayMemberPath="Name"
                          Height="120"
                          SelectionChanged="OnNotebookSelectionChanged" />
                <TextBlock Text="Sections" />
                <ListView x:Name="SectionsList"
                          DisplayMemberPath="Name"
                          Height="120"
                          SelectionChanged="OnSectionSelectionChanged" />
                <TextBlock Text="Pages (Ctrl/Shift to multi-select)" />
                <ListView x:Name="PagesList"
                          DisplayMemberPath="Name"
                          Height="120"
                          SelectionMode="Multiple" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnRefreshClicked" Content="Refresh" Style="{StaticResource SecondaryAction}" />
                    <Button Click="OnDiagnosticsClicked" Content="Diagnostics" Style="{StaticResource SecondaryAction}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Export Options" />
                <TextBox x:Name="OutputPathBox" PlaceholderText="Output directory" />
                <CheckBox x:Name="IncludeAttachmentsCheckBox" Content="Include attachments" IsChecked="True" />
                <CheckBox x:Name="FlattenHierarchyCheckBox" Content="Flatten hierarchy" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnChooseOutputClicked" Content="Choose Output" Style="{StaticResource SecondaryAction}" />
                    <Button Click="OnExportClicked" Content="Export" Style="{StaticResource PrimaryAction}" />
                </StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Logs" />
                <ListView x:Name="LogList" Height="160" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="8">
            <ProgressBar x:Name="ExportProgress" Height="8" Minimum="0" Maximum="100" Value="0" />
            <TextBlock x:Name="StatusText" Style="{StaticResource SubtitleText}" Text="Ready." />
        </StackPanel>
    </Grid>
</Page>

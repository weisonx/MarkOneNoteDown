<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="MarkOneNoteDown.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MarkOneNoteDown.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    Background="{StaticResource PageBackgroundBrush}"
    mc:Ignorable="d">
    <Grid Padding="24" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="6">
            <TextBlock Style="{StaticResource TitleText}" Text="MarkOneNoteDown" />
            <TextBlock Style="{StaticResource SubtitleText}" Text="OneNote 导出文件转 Markdown（HTML/PDF）" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="来源（OneNote 导出文件夹）" />
                <TextBox x:Name="SourcePathBox" PlaceholderText="请选择包含 HTML 或 PDF 的导出文件夹" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnChooseSourceClicked" Content="选择来源" Style="{StaticResource SecondaryAction}" />
                    <Button Click="OnLoadPagesClicked" Content="加载页面" Style="{StaticResource SecondaryAction}" />
                </StackPanel>
                <TextBlock Text="页面列表（按住 Ctrl/Shift 多选）" />
                <ListView x:Name="PagesList"
                          DisplayMemberPath="Name"
                          Height="260"
                          SelectionMode="Multiple" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="导出选项" />
                <TextBox x:Name="OutputPathBox" PlaceholderText="输出目录" />
                <CheckBox x:Name="IncludeAttachmentsCheckBox" Content="包含附件" IsChecked="True" />
                <CheckBox x:Name="FlattenHierarchyCheckBox" Content="扁平化目录结构" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnChooseOutputClicked" Content="选择输出" Style="{StaticResource SecondaryAction}" />
                    <Button Click="OnExportClicked" Content="开始导出" Style="{StaticResource PrimaryAction}" />
                </StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="日志" />
                <ListView x:Name="LogList" Height="160">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="8">
            <ProgressBar x:Name="ExportProgress" Height="8" Minimum="0" Maximum="100" Value="0" />
            <TextBlock x:Name="StatusText" Style="{StaticResource SubtitleText}" Text="就绪。" />
        </StackPanel>
    </Grid>
</Page>
